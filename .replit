modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python Orchestrator"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "C++ Engine"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd gui && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Python Orchestrator"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd orchestrator && python main.py"

[[workflows.workflow]]
name = "C++ Engine"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "engine/build/yank_engine 6800"
waitForPort = 6800

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6800
externalPort = 6800

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd gui && npm run build"]
publicDir = "gui/dist"
